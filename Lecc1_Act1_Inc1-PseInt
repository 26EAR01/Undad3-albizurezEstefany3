Algoritmo sin_titulo
	definir notas, i, suma como entero 
	Dimensionar notas[10]
	
	//solicitar notas
	notas[1]=78
	Para i=1 Hasta 10 Con Paso 1 Hacer
		Escribir "Digite la nota", i, ":"
		leer notas[i]
		suma=suma+notas[1]
	Fin Para
	//Mostrar notas
	Limpiar Pantalla
	Para i=1 Hasta 10 Con Paso 1 Hacer
		Escribir "nota",i,"=",notas[i]
		 Esperar 1 Segundos
	Fin Para
	Escribir  "El promedio de las notas son: ",(suma/10)
	
FinAlgoritmo
